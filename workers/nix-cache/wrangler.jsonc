{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nix-cache-router",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-10",
  "workers_dev": false,

  // Bind cache.nakasyou.how/* in the dashboard or with `wrangler deploy
  // --route cache.nakasyou.how/*`. Keeping the zone ID out of this repository
  // makes the configuration portable.
  "vars": {
    "GITHUB_REPOSITORY": "nakasyou/dotfiles"
  }
}
